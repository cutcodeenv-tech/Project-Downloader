import os
import shutil
import csv
import re
import sys
import subprocess
from datetime import datetime
import xml.etree.ElementTree as ET
from xml.dom import minidom

# Проверка и автоматическая установка необходимых зависимостей
def check_and_install_dependencies():
    """Проверяет наличие зависимостей и устанавливает их при необходимости"""
    
    # Проверка ffmpeg
    try:
        subprocess.run(['ffmpeg', '-version'], capture_output=True, check=True)
    except (FileNotFoundError, subprocess.CalledProcessError):
        print("⚠️  FFmpeg не найден")
        print("📦 Для установки ffmpeg выполните:")
        print("   macOS: brew install ffmpeg")
        print("   Linux: sudo apt-get install ffmpeg")
        print("\n❌ Установите ffmpeg и запустите скрипт снова")
        sys.exit(1)
    
    # Проверка pydub
    try:
        import pydub
    except ImportError:
        print("=" * 60)
        print("📦 Библиотека pydub не найдена")
        print("=" * 60)
        print("\n🔄 Автоматическая установка pydub...")
        
        try:
            # Пытаемся установить через pip
            subprocess.check_call([sys.executable, '-m', 'pip', 'install', 'pydub>=0.25.1'])
            print("✓ Библиотека pydub успешно установлена!")
            print("\n🔄 Перезапустите скрипт для продолжения работы")
            sys.exit(0)
        except subprocess.CalledProcessError as e:
            print(f"\n❌ Ошибка установки: {e}")
            print("\n💡 Попробуйте установить вручную:")
            print("   pip3 install -r requirements.txt")
            print("   или: pip3 install pydub")
            sys.exit(1)

# Проверяем зависимости при запуске
check_and_install_dependencies()

# Импортируем после проверки
from pydub import AudioSegment
from pydub.silence import detect_nonsilent

def get_project_name():
    """Запрашивает название проекта и проверяет его формат"""
    while True:
        name = input('Введите название проекта: ').strip()
        if not name:
            print('Ошибка: название проекта не может быть пустым.')
            continue
        
        # Проверяем формат osnovateli_doc_{name}
        pattern = r'^osnovateli_doc_[a-zA-Z0-9_]+$'
        if not re.match(pattern, name):
            print('Ошибка: название должно соответствовать формату osnovateli_doc_{name}')
            print('Пример: osnovateli_doc_polonsky')
            continue
        
        return name

def get_threshold(database_dir):
    """
    Читает порог громкости из threshold.txt
    Если файл не существует или пустой - создает с дефолтным значением -40
    """
    threshold_file = os.path.join(database_dir, 'threshold.txt')
    default_threshold = -40
    
    # Создаем database директорию если её нет
    os.makedirs(database_dir, exist_ok=True)
    
        # Проверяем существование файла
    if os.path.exists(threshold_file):
        try:
            with open(threshold_file, 'r', encoding='utf-8') as f:
                content = f.read().strip()
                
            if content:
                # Пытаемся прочитать число
                threshold = float(content)
                print(f"✓ Порог громкости прочитан из threshold.txt: {threshold} dB")
                return threshold
            else:
                print(f"⚠️  Файл threshold.txt пустой")
        except (ValueError, Exception) as e:
            print(f"⚠️  Ошибка чтения threshold.txt: {e}")
    
    # Создаем файл с дефолтным значением
    print(f"📝 Создаю threshold.txt с дефолтным значением: {default_threshold} dB")
    with open(threshold_file, 'w', encoding='utf-8') as f:
        f.write(str(default_threshold))
    
    return default_threshold

def find_audio_file(voiceover_dir, project_name):
    """
    Находит аудиофайл в директории voiceover
    Приоритет: {project_name}_voiceover.wav, затем любой .wav файл
    """
    if not os.path.exists(voiceover_dir):
        print(f"❌ Директория voiceover не найдена: {voiceover_dir}")
        return None
    
    # Ищем файл с ожидаемым названием
    expected_filename = f"{project_name}_voiceover.wav"
    expected_path = os.path.join(voiceover_dir, expected_filename)
    
    if os.path.exists(expected_path):
        print(f"✓ Найден аудиофайл: {expected_filename}")
        return expected_path
    
    # Ищем любой .wav файл
    wav_files = [f for f in os.listdir(voiceover_dir) 
                 if f.lower().endswith('.wav') and os.path.isfile(os.path.join(voiceover_dir, f))]
    
    if not wav_files:
        print(f"❌ В директории voiceover не найдено .wav файлов")
            return None
        
    if len(wav_files) > 1:
        print(f"⚠️  Найдено {len(wav_files)} .wav файлов:")
        for i, f in enumerate(wav_files, 1):
            print(f"  {i}. {f}")
        print(f"⚠️  Использую первый файл: {wav_files[0]}")
    
    audio_path = os.path.join(voiceover_dir, wav_files[0])
    print(f"✓ Найден аудиофайл: {wav_files[0]}")
    return audio_path

def analyze_audio(audio_path, threshold_db):
    """
    Анализирует аудиофайл и определяет сегменты с голосом
    
    Parameters:
    - audio_path: путь к аудиофайлу
    - threshold_db: порог громкости в dB (например, -35)
    
    Returns:
    - список сегментов с голосом [(start_ms, end_ms), ...]
    """
    print(f"\n=== АНАЛИЗ АУДИОФАЙЛА ===")
    print(f"Файл: {os.path.basename(audio_path)}")
    print(f"Порог громкости: {threshold_db} dB")
    
    try:
        # Загружаем аудиофайл
        print("📂 Загружаю аудиофайл...")
        audio = AudioSegment.from_wav(audio_path)
        
        duration_seconds = len(audio) / 1000.0
        print(f"✓ Длительность аудио: {duration_seconds:.2f} сек ({len(audio)} мс)")
        print(f"✓ Частота дискретизации: {audio.frame_rate} Hz")
        print(f"✓ Каналы: {audio.channels}")
        
        # Определяем сегменты с голосом (не тишина)
        # detect_nonsilent возвращает сегменты, где громкость ВЫШЕ порога
        # min_silence_len - минимальная длина тишины (мс)
        # silence_thresh - порог в dBFS
        # seek_step - шаг анализа (мс), меньше = точнее, но медленнее
        
        print("🔍 Анализирую аудио для поиска участков с голосом...")
        print("   (это может занять некоторое время для длинных файлов)")
        
        min_silence_len = 300  # минимум 300мс тишины для разделения сегментов
        seek_step = 10  # анализируем каждые 10мс для точности
        
        voice_segments = detect_nonsilent(
            audio,
            min_silence_len=min_silence_len,
            silence_thresh=threshold_db,
            seek_step=seek_step
        )
        
        if not voice_segments:
            print("⚠️  Не найдено участков с голосом!")
            print("💡 Возможно, порог слишком высокий. Попробуйте уменьшить значение в threshold.txt")
            return []
        
        # Преобразуем в секунды для удобства отображения
        print(f"\n✓ Найдено {len(voice_segments)} сегментов с голосом:")
        total_voice_duration = 0
        
        for i, (start_ms, end_ms) in enumerate(voice_segments[:10], 1):  # показываем первые 10
            duration_ms = end_ms - start_ms
            total_voice_duration += duration_ms
            start_sec = start_ms / 1000.0
            end_sec = end_ms / 1000.0
            duration_sec = duration_ms / 1000.0
            print(f"  {i}. {start_sec:.2f}с - {end_sec:.2f}с (длительность: {duration_sec:.2f}с)")
        
        if len(voice_segments) > 10:
            print(f"  ... и еще {len(voice_segments) - 10} сегментов")
            for start_ms, end_ms in voice_segments[10:]:
                total_voice_duration += (end_ms - start_ms)
        
        total_voice_sec = total_voice_duration / 1000.0
        silence_sec = duration_seconds - total_voice_sec
        voice_percent = (total_voice_sec / duration_seconds) * 100
        
        print(f"\n📊 Статистика:")
        print(f"  Общая длительность: {duration_seconds:.2f}с")
        print(f"  Голос: {total_voice_sec:.2f}с ({voice_percent:.1f}%)")
        print(f"  Тишина (вырезано): {silence_sec:.2f}с ({100-voice_percent:.1f}%)")
        
        return voice_segments
        
    except FileNotFoundError:
        print(f"❌ Файл не найден: {audio_path}")
        return []
    except Exception as e:
        print(f"❌ Ошибка анализа аудио: {e}")
        import traceback
        traceback.print_exc()
        return []

def format_timecode(milliseconds, framerate=25):
    """
    Преобразует миллисекунды в таймкод формата HH:MM:SS:FF
    
    Parameters:
    - milliseconds: время в миллисекундах
    - framerate: частота кадров (по умолчанию 25 fps)
    
    Returns:
    - строка таймкода "HH:MM:SS:FF"
    """
    total_seconds = milliseconds / 1000.0
    hours = int(total_seconds // 3600)
    minutes = int((total_seconds % 3600) // 60)
    seconds = int(total_seconds % 60)
    frames = int((total_seconds - int(total_seconds)) * framerate)
    
    return f"{hours:02d}:{minutes:02d}:{seconds:02d}:{frames:02d}"

def get_audio_duration_frames(audio_path, framerate=25):
    """Получает общую длительность аудио в кадрах"""
    try:
        audio = AudioSegment.from_wav(audio_path)
        duration_ms = len(audio)
        duration_frames = int(duration_ms * framerate / 1000)
        return duration_frames
    except:
        return 0

def create_xml_timeline(voice_segments, audio_path, project_name, output_dir):
    """
    Создает XML-файл с таймлайном в формате DaVinci Resolve
    
    Parameters:
    - voice_segments: список сегментов [(start_ms, end_ms), ...]
    - audio_path: путь к исходному аудиофайлу
    - project_name: название проекта
    - output_dir: директория для сохранения XML
    
    Returns:
    - путь к созданному XML файлу или None
    """
    print(f"\n=== СОЗДАНИЕ XML ТАЙМЛАЙНА ===")
    
    if not voice_segments:
        print("❌ Нет сегментов для создания XML")
        return None
    
    try:
        from urllib.parse import quote
        
        # Создаем output директорию если её нет
        os.makedirs(output_dir, exist_ok=True)
        
        framerate = 25  # PAL стандарт
        filename = os.path.basename(audio_path)
        file_id = f"{filename} 1"
        
        # Получаем общую длительность аудио
        total_audio_duration = get_audio_duration_frames(audio_path, framerate)
        
        # Создаем корневой элемент
        xmeml = ET.Element('xmeml', version="5")
        
        # Создаем sequence
        sequence = ET.SubElement(xmeml, 'sequence')
        ET.SubElement(sequence, 'name').text = f"{project_name}_voiceover_timeline"
        
        # Вычисляем общую длительность таймлайна
        timeline_duration = 0
        for start_ms, end_ms in voice_segments:
            timeline_duration += int((end_ms - start_ms) * framerate / 1000)
        
        ET.SubElement(sequence, 'duration').text = str(timeline_duration)
        
        # Rate
        rate = ET.SubElement(sequence, 'rate')
        ET.SubElement(rate, 'timebase').text = str(framerate)
        ET.SubElement(rate, 'ntsc').text = 'FALSE'
        
        # In/Out для sequence
        ET.SubElement(sequence, 'in').text = '-1'
        ET.SubElement(sequence, 'out').text = '-1'
        
        # Timecode
        timecode = ET.SubElement(sequence, 'timecode')
        ET.SubElement(timecode, 'string').text = '00:00:00:00'
        ET.SubElement(timecode, 'frame').text = '0'
        ET.SubElement(timecode, 'displayformat').text = 'NDF'
        rate_tc = ET.SubElement(timecode, 'rate')
        ET.SubElement(rate_tc, 'timebase').text = str(framerate)
        ET.SubElement(rate_tc, 'ntsc').text = 'FALSE'
        
        # Media
        media = ET.SubElement(sequence, 'media')
        
        # Video track (пустой, но обязательный для Resolve)
        video = ET.SubElement(media, 'video')
        video_track = ET.SubElement(video, 'track')
        ET.SubElement(video_track, 'enabled').text = 'TRUE'
        ET.SubElement(video_track, 'locked').text = 'FALSE'
        
        # Format для video
        video_format = ET.SubElement(video, 'format')
        samplechar = ET.SubElement(video_format, 'samplecharacteristics')
        ET.SubElement(samplechar, 'width').text = '1920'
        ET.SubElement(samplechar, 'height').text = '1080'
        ET.SubElement(samplechar, 'pixelaspectratio').text = 'square'
        
        format_rate = ET.SubElement(samplechar, 'rate')
        ET.SubElement(format_rate, 'timebase').text = str(framerate)
        ET.SubElement(format_rate, 'ntsc').text = 'FALSE'
        
        codec = ET.SubElement(samplechar, 'codec')
        appdata = ET.SubElement(codec, 'appspecificdata')
        ET.SubElement(appdata, 'appname').text = 'Final Cut Pro'
        ET.SubElement(appdata, 'appmanufacturer').text = 'Apple Inc.'
        data = ET.SubElement(appdata, 'data')
        ET.SubElement(data, 'qtcodec')
        
        # Audio track
        audio = ET.SubElement(media, 'audio')
        track = ET.SubElement(audio, 'track')
        
        # Добавляем clipitem для каждого сегмента с голосом
        timeline_position = 0  # позиция на таймлайне в кадрах
        
        for i, (start_ms, end_ms) in enumerate(voice_segments):
            duration_ms = end_ms - start_ms
            duration_frames = int(duration_ms * framerate / 1000)
            
            # Создаем clipitem
            clipitem_id = f"{filename} {i}"
            clipitem = ET.SubElement(track, 'clipitem', id=clipitem_id)
            ET.SubElement(clipitem, 'name').text = filename
            ET.SubElement(clipitem, 'duration').text = str(total_audio_duration)
            
            # Rate для клипа
            clip_rate = ET.SubElement(clipitem, 'rate')
            ET.SubElement(clip_rate, 'timebase').text = str(framerate)
            ET.SubElement(clip_rate, 'ntsc').text = 'FALSE'
            
            # Позиция на таймлайне
            ET.SubElement(clipitem, 'start').text = str(timeline_position)
            ET.SubElement(clipitem, 'end').text = str(timeline_position + duration_frames)
            ET.SubElement(clipitem, 'enabled').text = 'TRUE'
            
            # In/Out точки в исходном файле
            in_frame = int(start_ms * framerate / 1000)
            out_frame = int(end_ms * framerate / 1000)
            ET.SubElement(clipitem, 'in').text = str(in_frame)
            ET.SubElement(clipitem, 'out').text = str(out_frame)
            
            # Ссылка на файл
            if i == 0:
                # Первый clipitem - полное описание файла
                file_elem = ET.SubElement(clipitem, 'file', id=file_id)
                ET.SubElement(file_elem, 'duration').text = str(total_audio_duration)
                
                file_rate = ET.SubElement(file_elem, 'rate')
                ET.SubElement(file_rate, 'timebase').text = str(framerate)
                ET.SubElement(file_rate, 'ntsc').text = 'FALSE'
                
                ET.SubElement(file_elem, 'name').text = filename
                
                # URL кодируем правильно для Resolve
                # Resolve требует формат: file:// + закодированный путь (путь уже начинается с /)
                abs_path = os.path.abspath(audio_path)
                # Кодируем все символы кроме слэшей, включая кириллицу и пробелы
                encoded_path = quote(abs_path, safe='/')
                ET.SubElement(file_elem, 'pathurl').text = f"file://{encoded_path}"
                
                # Timecode для файла
                file_tc = ET.SubElement(file_elem, 'timecode')
                ET.SubElement(file_tc, 'string').text = '00:00:00:00'
                ET.SubElement(file_tc, 'frame').text = '0'
                ET.SubElement(file_tc, 'displayformat').text = 'NDF'
                
                file_tc_rate = ET.SubElement(file_tc, 'rate')
                ET.SubElement(file_tc_rate, 'timebase').text = str(framerate)
                ET.SubElement(file_tc_rate, 'ntsc').text = 'FALSE'
                
                # Media для файла
                file_media = ET.SubElement(file_elem, 'media')
                file_audio = ET.SubElement(file_media, 'audio')
                ET.SubElement(file_audio, 'channelcount').text = '1'
            else:
                # Остальные clipitem - только ссылка на файл
                ET.SubElement(clipitem, 'file', id=file_id)
            
            # Source track
            sourcetrack = ET.SubElement(clipitem, 'sourcetrack')
            ET.SubElement(sourcetrack, 'mediatype').text = 'audio'
            ET.SubElement(sourcetrack, 'trackindex').text = '1'
            
            # Filter 1: Audio Levels
            filter1 = ET.SubElement(clipitem, 'filter')
            ET.SubElement(filter1, 'enabled').text = 'TRUE'
            ET.SubElement(filter1, 'start').text = '0'
            ET.SubElement(filter1, 'end').text = str(total_audio_duration)
            
            effect1 = ET.SubElement(filter1, 'effect')
            ET.SubElement(effect1, 'name').text = 'Audio Levels'
            ET.SubElement(effect1, 'effectid').text = 'audiolevels'
            ET.SubElement(effect1, 'effecttype').text = 'audiolevels'
            ET.SubElement(effect1, 'mediatype').text = 'audio'
            ET.SubElement(effect1, 'effectcategory').text = 'audiolevels'
            
            param1 = ET.SubElement(effect1, 'parameter')
            ET.SubElement(param1, 'name').text = 'Level'
            ET.SubElement(param1, 'parameterid').text = 'level'
            ET.SubElement(param1, 'value').text = '1'
            ET.SubElement(param1, 'valuemin').text = '1e-05'
            ET.SubElement(param1, 'valuemax').text = '31.6228'
            
            # Filter 2: Audio Pan
            filter2 = ET.SubElement(clipitem, 'filter')
            ET.SubElement(filter2, 'enabled').text = 'TRUE'
            ET.SubElement(filter2, 'start').text = '0'
            ET.SubElement(filter2, 'end').text = str(total_audio_duration)
            
            effect2 = ET.SubElement(filter2, 'effect')
            ET.SubElement(effect2, 'name').text = 'Audio Pan'
            ET.SubElement(effect2, 'effectid').text = 'audiopan'
            ET.SubElement(effect2, 'effecttype').text = 'audiopan'
            ET.SubElement(effect2, 'mediatype').text = 'audio'
            ET.SubElement(effect2, 'effectcategory').text = 'audiopan'
            
            param2 = ET.SubElement(effect2, 'parameter')
            ET.SubElement(param2, 'name').text = 'Pan'
            ET.SubElement(param2, 'parameterid').text = 'pan'
            ET.SubElement(param2, 'value').text = '0'
            ET.SubElement(param2, 'valuemin').text = '-1'
            ET.SubElement(param2, 'valuemax').text = '1'
            
            # Comments (пустой, но обязательный)
            ET.SubElement(clipitem, 'comments')
            
            # Обновляем позицию на таймлайне
            timeline_position += duration_frames
        
        # Закрываем track
        ET.SubElement(track, 'enabled').text = 'TRUE'
        ET.SubElement(track, 'locked').text = 'FALSE'
        
        # Конвертируем в красивый XML
        xml_string = ET.tostring(xmeml, encoding='utf-8')
        dom = minidom.parseString(xml_string)
        pretty_xml = dom.toprettyxml(indent="    ", encoding='utf-8').decode('utf-8')
        
        # Исправляем заголовок XML - убираем лишние атрибуты и добавляем DOCTYPE
        # Находим первую строку и заменяем её
        lines = pretty_xml.split('\n')
        if lines[0].startswith('<?xml'):
            lines[0] = '<?xml version="1.0" encoding="UTF-8"?>'
            lines.insert(1, '<!DOCTYPE xmeml>')
            pretty_xml = '\n'.join(lines)
        
        # Сохраняем XML
        xml_filename = f"{project_name}_voiceover_timeline.xml"
        xml_path = os.path.join(output_dir, xml_filename)
        
        with open(xml_path, 'w', encoding='utf-8') as f:
            f.write(pretty_xml)
        
        print(f"✓ XML файл создан: {xml_filename}")
        print(f"✓ Расположение: {xml_path}")
        print(f"✓ Сегментов в таймлайне: {len(voice_segments)}")
        
        # Вычисляем общую длительность на таймлайне
        total_duration_sec = timeline_position / framerate
        print(f"✓ Общая длительность таймлайна: {total_duration_sec:.2f}с")
        
        return xml_path
        
    except Exception as e:
        print(f"❌ Ошибка создания XML: {e}")
        import traceback
        traceback.print_exc()
        return None

def create_backup(file_path, backup_dir):
    """Создает резервную копию файла"""
    try:
        os.makedirs(backup_dir, exist_ok=True)
        
        filename = os.path.basename(file_path)
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        backup_filename = f"{timestamp}_{filename}"
        backup_path = os.path.join(backup_dir, backup_filename)
        
        shutil.copy2(file_path, backup_path)
        print(f"✓ Создана резервная копия: {backup_filename}")
        return True
    except Exception as e:
        print(f"❌ Ошибка создания резервной копии: {e}")
        return False

def main():
    print("=" * 60)
    print("СКРИПТ АНАЛИЗА VOICEOVER И СОЗДАНИЯ XML ТАЙМЛАЙНА")
    print("=" * 60)
    
    # Получаем название проекта
    project_name = get_project_name()
    
    # Определяем пути
    data_dir = '/Users/theseus/Projects/osnovateli_doc_framework/data'
    project_dir = os.path.join(data_dir, project_name)
    
    # Проверяем существование проекта
    if not os.path.exists(project_dir):
        print(f"\n❌ Проект не найден: {project_dir}")
        print("💡 Сначала создайте структуру проекта с помощью скрипта 0_structure.py")
        return
    
    print(f"\n✓ Проект найден: {project_name}")
    
    # Определяем директории
    voiceover_dir = os.path.join(project_dir, 'voiceover')
    database_dir = os.path.join(project_dir, 'database')
    output_dir = os.path.join(project_dir, 'edit')
    backup_dir = os.path.join(project_dir, 'backup')
    
    # Шаг 1: Получаем порог громкости
    print(f"\n{'='*60}")
    print("ШАГ 1: ЧТЕНИЕ ПОРОГА ГРОМКОСТИ")
    print(f"{'='*60}")
    threshold_db = get_threshold(database_dir)
    
    # Шаг 2: Находим аудиофайл
    print(f"\n{'='*60}")
    print("ШАГ 2: ПОИСК АУДИОФАЙЛА")
    print(f"{'='*60}")
    audio_path = find_audio_file(voiceover_dir, project_name)
    
    if not audio_path:
        print("\n❌ Аудиофайл не найден!")
        print(f"💡 Поместите .wav файл в директорию: {voiceover_dir}")
        return
    
    # Шаг 3: Анализируем аудио
    print(f"\n{'='*60}")
    print("ШАГ 3: АНАЛИЗ АУДИО")
    print(f"{'='*60}")
    voice_segments = analyze_audio(audio_path, threshold_db)
    
    if not voice_segments:
        print("\n⚠️  Анализ не дал результатов")
        print("💡 Рекомендации:")
        print("   1. Проверьте, что в аудиофайле есть звук")
        print(f"   2. Попробуйте изменить порог в файле: {os.path.join(database_dir, 'threshold.txt')}")
        print(f"   3. Текущий порог: {threshold_db} dB")
        print(f"   4. Попробуйте значение от -50 до -30 dB")
        return
    
    # Шаг 4: Создаем XML таймлайн
    print(f"\n{'='*60}")
    print("ШАГ 4: СОЗДАНИЕ XML ТАЙМЛАЙНА")
    print(f"{'='*60}")
    xml_path = create_xml_timeline(voice_segments, audio_path, project_name, output_dir)
    
    if not xml_path:
        print("\n❌ Не удалось создать XML таймлайн")
        return
    
    # Итоговая информация
    print(f"\n{'='*60}")
    print("✅ ГОТОВО!")
    print(f"{'='*60}")
    print(f"📁 XML таймлайн: {xml_path}")
    print(f"📊 Порог громкости: {threshold_db} dB")
    print(f"🎵 Сегментов с голосом: {len(voice_segments)}")
    print(f"\n💡 Вы можете импортировать XML файл в монтажную программу")
    print(f"💡 Для настройки порога редактируйте: {os.path.join(database_dir, 'threshold.txt')}")

if __name__ == "__main__":
    main()
